{
  "name": "@elearning/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "seed:import": "ts-node -r tsconfig-paths/register src/database/import.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:prod": "typeorm",
    "migration:generate": "pnpm typeorm migration:generate -d src/database/data-source.ts",
    "migration:create": "pnpm typeorm migration:create",
    "migration:run:dev": "pnpm typeorm migration:run -d src/database/data-source.ts",
    "migration:run:prod": "pnpm typeorm:prod migration:run -d dist/database/data-source.js",
    "migration:revert:dev": "pnpm typeorm migration:revert -d src/database/data-source.ts",
    "migration:revert:prod": "pnpm typeorm:prod migration:revert -d dist/database/data-source.js",
    "migration:show": "pnpm typeorm migration:show -d src/database/data-source.ts",
    "schema:drop": "pnpm typeorm schema:drop -d src/database/data-source.ts",
    "lint": "prettier --check \"src/**/*.ts\"",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@elearning/contracts": "workspace:*",
    "@elearning/core": "workspace:*",
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.26",
    "@nestjs/platform-express": "11.1.26",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/typeorm": "11.0.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "nestjs-pino": "4.6.1",
    "pg": "8.21.0",
    "pino-http": "11.0.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "1.0.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "argon2": "0.44.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "11.1.26",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "4.0.1",
    "@types/passport": "^1.0.17",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3"
  }
}
