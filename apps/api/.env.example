NODE_ENV=development
APP_PORT=4000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=elearning
DB_PASSWORD=elearning
DB_DATABASE=elearning
# dev convenience: auto-sync schema from entities. Use migrations in production.
DB_SYNCHRONIZE=true

LOG_LEVEL=debug
SWAGGER_ENABLED=true

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# Internal API key (for admin endpoints, incl. POST /admin/content/import)
INTERNAL_API_KEY=change-me-in-production

# Object storage (MinIO in dev — see docker-compose.yml; R2/S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=soundwell-audio
S3_ACCESS_KEY=elearning
S3_SECRET_KEY=elearning-secret
S3_PUBLIC_URL=http://localhost:9000/soundwell-audio
S3_FORCE_PATH_STYLE=true

# Generative AI — powers speaking (voice) evaluation.
# AI_PROVIDER selects the active provider (gemini | openai). The voice-attempt
# endpoint returns 503 until the active provider has a key.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Email (SMTP) — env names mirror vault/admin_be
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@soundwell.app
EMAIL_FROM_NAME=Soundwell
USE_TLS=false

# Google Sign-In (Passport OAuth) — web client ID/secret + callback URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Frontend coordinates for magic-link URLs
WEB_APP_URL=http://localhost:3000
APP_DEEP_LINK_SCHEME=elearning
