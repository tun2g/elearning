NODE_ENV=development
APP_PORT=4000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=elearning
DB_PASSWORD=elearning
DB_DATABASE=elearning
# dev convenience: auto-sync schema from entities. Use migrations in production.
DB_SYNCHRONIZE=true

LOG_LEVEL=debug
SWAGGER_ENABLED=true

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# Internal API key (for admin endpoints, incl. POST /admin/content/import)
INTERNAL_API_KEY=change-me-in-production

# Object storage (MinIO in dev — see docker-compose.yml; R2/S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=soundwell-audio
S3_ACCESS_KEY=elearning
S3_SECRET_KEY=elearning-secret
S3_PUBLIC_URL=http://localhost:9000/soundwell-audio
S3_FORCE_PATH_STYLE=true
