{
  "lessons": [
    {
      "slug": "greetings-and-introductions",
      "title": "Greetings and Introductions",
      "description": "Everyday phrases for meeting someone new.",
      "level": "beginner",
      "topicSlug": "greetings-and-introductions",
      "source": "Soundwell Editorial",
      "sentences": [
        {
          "order": 1,
          "text": "Hi, it's nice to meet you.",
          "ipa": "/haɪ ɪts naɪs tə miːt juː/",
          "translation": "Chào, rất vui được gặp bạn."
        },
        {
          "order": 2,
          "text": "What's your name?",
          "ipa": "/wɒts jɔː neɪm/",
          "translation": "Bạn tên là gì?"
        },
        {
          "order": 3,
          "text": "Where are you from?",
          "ipa": "/weər ɑː juː frɒm/",
          "translation": "Bạn đến từ đâu?"
        },
        {
          "order": 4,
          "text": "I'm from Vietnam.",
          "ipa": "/aɪm frɒm ˌvjetˈnɑːm/",
          "translation": "Tôi đến từ Việt Nam."
        },
        {
          "order": 5,
          "text": "It was great talking to you.",
          "ipa": "/ɪt wɒz ɡreɪt ˈtɔːkɪŋ tə juː/",
          "translation": "Rất vui được nói chuyện với bạn."
        }
      ]
    },
    {
      "slug": "ordering-at-a-cafe",
      "title": "Ordering at a Café",
      "description": "Order drinks and food politely.",
      "level": "beginner",
      "topicSlug": "at-a-cafe",
      "source": "Soundwell Editorial",
      "sentences": [
        {
          "order": 1,
          "text": "Could I have a coffee, please?",
          "ipa": "/kʊd aɪ hæv ə ˈkɒfi pliːz/",
          "translation": "Cho tôi một ly cà phê được không?"
        },
        {
          "order": 2,
          "text": "Would you like anything to eat?",
          "ipa": "/wʊd juː laɪk ˈeniθɪŋ tʊ iːt/",
          "translation": "Bạn có muốn ăn gì không?"
        },
        {
          "order": 3,
          "text": "I'll have a sandwich, thanks.",
          "ipa": "/aɪl hæv ə ˈsænwɪdʒ θæŋks/",
          "translation": "Cho tôi một chiếc bánh mì kẹp, cảm ơn."
        },
        {
          "order": 4,
          "text": "How much is that?",
          "ipa": "/haʊ mʌtʃ ɪz ðæt/",
          "translation": "Cái đó giá bao nhiêu?"
        },
        {
          "order": 5,
          "text": "Can I pay by card?",
          "ipa": "/kæn aɪ peɪ baɪ kɑːd/",
          "translation": "Tôi trả bằng thẻ được không?"
        }
      ]
    },
    {
      "slug": "weekend-small-talk",
      "title": "Weekend Small Talk",
      "description": "Chat naturally about your weekend plans.",
      "level": "intermediate",
      "topicSlug": "hobbies-and-free-time",
      "source": "Soundwell Editorial",
      "sentences": [
        {
          "order": 1,
          "text": "Do you have any plans for the weekend?",
          "ipa": "/duː juː hæv ˈeni plænz fɔː ðə ˈwiːkend/",
          "translation": "Cuối tuần bạn có kế hoạch gì không?"
        },
        {
          "order": 2,
          "text": "I'm thinking of going hiking on Saturday.",
          "ipa": "/aɪm ˈθɪŋkɪŋ əv ˈɡəʊɪŋ ˈhaɪkɪŋ ɒn ˈsætədeɪ/",
          "translation": "Tôi đang định đi leo núi vào thứ Bảy."
        },
        {
          "order": 3,
          "text": "That sounds like a lot of fun.",
          "ipa": "/ðæt saʊndz laɪk ə lɒt əv fʌn/",
          "translation": "Nghe có vẻ rất vui."
        },
        {
          "order": 4,
          "text": "We should catch up sometime next week.",
          "ipa": "/wiː ʃʊd kætʃ ʌp ˈsʌmtaɪm nekst wiːk/",
          "translation": "Tuần sau mình nên gặp nhau lúc nào đó."
        },
        {
          "order": 5,
          "text": "Have a great weekend!",
          "ipa": "/hæv ə ɡreɪt ˈwiːkend/",
          "translation": "Chúc bạn cuối tuần vui vẻ!"
        }
      ]
    }
  ],
